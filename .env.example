# AgentGrid Configuration

# --- Agent ---
AGENTGRID_LOG_LEVEL=INFO
AGENTGRID_ENV=development

# --- Memory ---
AGENTGRID_MEMORY_BACKEND=sqlite
AGENTGRID_MEMORY_DSN=sqlite+aiosqlite:///agentgrid.db

# --- LLM (when connecting to providers) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Observability ---
AGENTGRID_TRACING_ENABLED=true
AGENTGRID_METRICS_ENABLED=true

# --- Auth ---
AGENTGRID_AUTH_ENABLED=false
AGENTGRID_API_KEY=
